PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/chainforge
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=change-this-session-secret
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=debug

# Redis (optional; falls back to in-memory cache if omitted)
REDIS_URL=redis://127.0.0.1:6379

# Pricing / explorers
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=
ANKR_API_KEY=
COINGECKO_API_KEY=
BITCOIN_API_BASE=https://mempool.space/api

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5001/api/auth/github/callback

# Hidden admin route and allowlist
ADMIN_ROUTE_SLUG=replace-with-32-char-random-string
ADMIN_ALLOWED_IPS=127.0.0.1/32,::1/128

# Email Configuration (for verification emails)
# For Gmail: Use App Password from Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Ethereal Email (for testing - auto-generated if SMTP not set)
# Get credentials from https://ethereal.email
ETHEREAL_USER=
ETHEREAL_PASS=

# Frontend URL for email links
CLIENT_URL=http://localhost:5173

# RPC endpoints (implemented chains + future adapter placeholders)
RPC_ETHEREUM=https://ethereum-rpc.publicnode.com
RPC_ETHEREUM_FALLBACK=
RPC_POLYGON=https://polygon-bor-rpc.publicnode.com
RPC_POLYGON_FALLBACK=
RPC_BNB=https://bsc-dataseed.binance.org
RPC_BNB_FALLBACK=
RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
RPC_AVALANCHE_FALLBACK=
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_ARBITRUM_FALLBACK=
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_OPTIMISM_FALLBACK=
RPC_BASE=https://mainnet.base.org
RPC_BASE_FALLBACK=
RPC_ZKSYNC=https://mainnet.era.zksync.io
RPC_ZKSYNC_FALLBACK=
RPC_LINEA=https://rpc.linea.build
RPC_LINEA_FALLBACK=
RPC_SOLANA=https://api.mainnet-beta.solana.com
RPC_SOLANA_FALLBACK=
RPC_SUI=https://fullnode.mainnet.sui.io:443
RPC_SUI_FALLBACK=
RPC_BITCOIN=https://mempool.space/api
RPC_BITCOIN_FALLBACK=

# Placeholder RPC slots for future adapters
RPC_COSMOS=
RPC_NEAR=
RPC_TON=
RPC_TRON=
RPC_STARKNET=
RPC_APTOS=
